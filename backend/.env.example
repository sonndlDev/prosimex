# Prosimex MES Backend Configuration Example
# Copy this file to .env and update the values for your environment

# Database Connection
# Template: postgresql://[user]:[password]@[host]:[port]/[database_name]?schema=public
# For local dev usually: postgresql://postgres:postgres@localhost:5432/prosimex_mes
# For production, use strong credentials and your production host.
DATABASE_URL="postgresql://user:password@localhost:5432/prosimex_mes"

# Server Port
PORT=3000

# Security (Future use)
# JWT_SECRET="your_very_secret_key_here"
